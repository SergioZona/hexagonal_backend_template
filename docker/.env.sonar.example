# ─── SonarQube Image ────────────────────────────────────────────────────────
SONAR_IMAGE_VERSION=community

# ─── Postgres Image ──────────────────────────────────────────────────────────
POSTGRES_IMAGE_VERSION=18

# ─── Database Credentials ────────────────────────────────────────────────────
POSTGRES_USER=sonar
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sonar

# ─── Network / Access ────────────────────────────────────────────────────────
# Host port exposed by Docker (maps to container 9000)
SONAR_PORT=9000

# Public URL of your SonarQube instance (used for links in emails & scanner output)
# Set to your Dokploy custom domain, e.g. https://sonar.yourdomain.com
SONAR_HOST_URL=http://localhost:9000